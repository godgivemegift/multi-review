# ── Agent / 推理 ───────────────────────────────────────────────
# 'claude' = 用本地已登录的 claude 二进制(走订阅, 基本不额外花 API 钱)
# 'anthropic-api' = 用 ANTHROPIC_API_KEY 按量计费
INFERENCE_PROVIDER=claude
ANTHROPIC_MODEL=sonnet
RECHECK_MODEL=sonnet
# 发评论时中→英翻译用的轻量模型（机械活，不跟审核重模型走，避免卡顿）。haiku 更快 / sonnet 更稳
TRANSLATE_MODEL=sonnet
# 仅 INFERENCE_PROVIDER=anthropic-api 或本地 claude 未登录时需要
# ANTHROPIC_API_KEY=

# ── GitHub ─────────────────────────────────────────────────────
# 默认走你本地已绑定的 gh CLI(读 PR / diff / state, 发 review)。无需 token。
# 仅当你想用 Octokit 或提高速率时填:
# GITHUB_TOKEN=
# 粘贴纯数字 PR 时的默认仓库(可选, 项目里也能各自设)
# DEFAULT_REPO=Stakimo/stakimo-app

# ── 本地基础设施 ────────────────────────────────────────────────
PORT=3001
DB_PATH=./data/cockpit.db
# 每个 review 的 git worktree 落地根目录
REPOS_DIR=./data/worktrees
# 同时并行审核的最大数量(受 worktree / 算力约束)
MAX_CONCURRENCY=3
