# ── Agent · 推理 · Inference · Inférence ──────────────────────
# 中: 'claude' = 用本地已登录的 claude 二进制(走订阅, 基本不额外花 API 钱)
# EN: 'claude' = use the locally logged-in claude binary (uses your subscription, essentially no extra API cost)
# FR: 'claude' = utilise le binaire claude connecté localement (via l'abonnement, quasiment aucun coût API supplémentaire)
# 中: 'anthropic-api' = 用 ANTHROPIC_API_KEY 按量计费
# EN: 'anthropic-api' = use ANTHROPIC_API_KEY, billed per usage
# FR: 'anthropic-api' = utilise ANTHROPIC_API_KEY, facturé à l'usage
INFERENCE_PROVIDER=claude
# 中: 审核默认模型(项目配置里可按项目覆盖)。别名: sonnet / opus / haiku / default，或全名 claude-opus-4-8
# EN: Default review model (overridable per project in its config). Aliases: sonnet / opus / haiku / default, or full name claude-opus-4-8
# FR: Modèle de revue par défaut (surchargeable par projet dans sa config). Alias : sonnet / opus / haiku / default, ou nom complet claude-opus-4-8
ANTHROPIC_MODEL=sonnet
# 中: 复审模型(留空则跟 ANTHROPIC_MODEL)
# EN: Recheck model (leave empty to follow ANTHROPIC_MODEL)
# FR: Modèle de recheck (laisser vide pour suivre ANTHROPIC_MODEL)
RECHECK_MODEL=sonnet
# 中: 发评论时中→英翻译用的轻量模型(机械活，不跟审核重模型走，避免卡顿)。haiku 更快 / sonnet 更稳
# EN: Lightweight model for Chinese→English translation when posting comments (mechanical work, kept off the heavy review model to avoid stalls). haiku = faster / sonnet = steadier
# FR: Modèle léger pour la traduction chinois→anglais à la publication des commentaires (tâche mécanique, séparée du gros modèle de revue pour éviter les ralentissements). haiku = plus rapide / sonnet = plus stable
TRANSLATE_MODEL=sonnet
# 中: 仅 INFERENCE_PROVIDER=anthropic-api 或本地 claude 未登录时需要
# EN: Required only when INFERENCE_PROVIDER=anthropic-api, or when the local claude isn't logged in
# FR: Nécessaire uniquement si INFERENCE_PROVIDER=anthropic-api, ou si le claude local n'est pas connecté
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ─────────────────────────────────────────────────────
# 中: 默认走你本地已绑定的 gh CLI(读 PR / diff / state, 发 review)。无需 token。
# EN: By default uses your locally authenticated gh CLI (reads PR / diff / state, posts reviews). No token needed.
# FR: Par défaut, utilise la CLI gh authentifiée localement (lit PR / diff / state, publie les reviews). Aucun token requis.
# 中: 仅当你想用 Octokit 或提高速率时填:
# EN: Fill this in only if you want to use Octokit or raise the rate limit:
# FR: À renseigner uniquement si vous voulez utiliser Octokit ou augmenter la limite de débit :
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# 中: 粘贴纯数字 PR 时的默认仓库(可选, 项目里也能各自设)
# EN: Default repo when pasting a bare PR number (optional; can also be set per project)
# FR: Dépôt par défaut quand on colle un numéro de PR brut (optionnel ; configurable aussi par projet)
# DEFAULT_REPO=owner/repo

# ── 本地基础设施 · Local infrastructure · Infrastructure locale ──
PORT=3001
DB_PATH=./data/cockpit.db
# 中: 每个 review 的 git worktree 落地根目录
# EN: Root directory where each review's git worktree lands
# FR: Répertoire racine où atterrit le git worktree de chaque review
REPOS_DIR=./data/worktrees
# 中: 同时并行审核的最大数量(受 worktree / 算力约束)
# EN: Maximum number of reviews running in parallel (bounded by worktree / compute)
# FR: Nombre maximum de revues en parallèle (limité par les worktrees / la puissance de calcul)
MAX_CONCURRENCY=3
